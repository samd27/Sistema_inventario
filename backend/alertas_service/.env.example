# Alertas Service
SECRET_KEY=change-me
FLASK_ENV=development

# BD de microservicios (TiDB 2, separada de inventario)
MICROSERVICES_DATABASE_URL=mysql+pymysql://user:password@host:4000/tienda_microservicios?charset=utf8mb4

# URL del backend principal (inventario)
INVENTORY_API_URL=http://127.0.0.1:8080

# URL del frontend desplegado en Railway
FRONTEND_URL=https://tu-frontend.up.railway.app

# Brevo HTTP API para notificaciones
BREVO_API_KEY=tu-api-key
BREVO_SENDER_EMAIL=tu-correo-verificado@example.com
BREVO_SENDER_NAME=Sistema Inventario
BREVO_API_URL=https://api.brevo.com/v3/smtp/email
ALERTS_TO_EMAIL=destino-alertas@example.com
