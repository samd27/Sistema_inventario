# Backend principal (inventario)
SECRET_KEY=change-me
FLASK_ENV=development

# BD principal de inventario (TiDB 1)
DATABASE_URL=mysql+pymysql://user:password@host:4000/tienda_inventario?charset=utf8mb4

# URLs de microservicios
ALERTAS_SERVICE_URL=http://127.0.0.1:8081
REPORTES_SERVICE_URL=http://127.0.0.1:8082
MICROSERVICES_TIMEOUT_SECONDS=5

# CORS frontend
FRONTEND_URL=http://localhost:5173
